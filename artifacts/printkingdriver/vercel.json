{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/brands/brother", "destination": "/brands/brand-a", "permanent": true },
    { "source": "/brands/brother/:path*", "destination": "/brands/brand-a/:path*", "permanent": true },
    { "source": "/brands/canon", "destination": "/brands/brand-b", "permanent": true },
    { "source": "/brands/canon/:path*", "destination": "/brands/brand-b/:path*", "permanent": true },
    { "source": "/brands/dell", "destination": "/brands/brand-c", "permanent": true },
    { "source": "/brands/dell/:path*", "destination": "/brands/brand-c/:path*", "permanent": true },
    { "source": "/brands/epson", "destination": "/brands/brand-d", "permanent": true },
    { "source": "/brands/epson/:path*", "destination": "/brands/brand-d/:path*", "permanent": true },
    { "source": "/brands/hp", "destination": "/brands/brand-e", "permanent": true },
    { "source": "/brands/hp/:path*", "destination": "/brands/brand-e/:path*", "permanent": true },
    { "source": "/brands/kyocera", "destination": "/brands/brand-f", "permanent": true },
    { "source": "/brands/kyocera/:path*", "destination": "/brands/brand-f/:path*", "permanent": true },
    { "source": "/brands/lexmark", "destination": "/brands/brand-g", "permanent": true },
    { "source": "/brands/lexmark/:path*", "destination": "/brands/brand-g/:path*", "permanent": true },
    { "source": "/brands/ricoh", "destination": "/brands/brand-h", "permanent": true },
    { "source": "/brands/ricoh/:path*", "destination": "/brands/brand-h/:path*", "permanent": true },
    { "source": "/brands/samsung", "destination": "/brands/brand-i", "permanent": true },
    { "source": "/brands/samsung/:path*", "destination": "/brands/brand-i/:path*", "permanent": true },
    { "source": "/brands/xerox", "destination": "/brands/brand-j", "permanent": true },
    { "source": "/brands/xerox/:path*", "destination": "/brands/brand-j/:path*", "permanent": true },
    { "source": "/guides", "destination": "/troubleshooting", "permanent": true },
    { "source": "/guides/windows-10-printer-setup", "destination": "/troubleshooting/driver-not-installing", "permanent": true },
    { "source": "/guides/windows-11-printer-setup", "destination": "/troubleshooting/driver-not-installing", "permanent": true },
    { "source": "/guides/macos-printer-setup", "destination": "/troubleshooting/driver-not-installing", "permanent": true },
    { "source": "/guides/linux-printer-setup", "destination": "/troubleshooting", "permanent": true },
    { "source": "/guides/wifi-printer-setup", "destination": "/troubleshooting/printer-wont-connect-wifi", "permanent": true },
    { "source": "/guides/ethernet-printer-setup", "destination": "/troubleshooting/printer-wont-connect-wifi", "permanent": true },
    { "source": "/guides/usb-printer-setup", "destination": "/troubleshooting/driver-not-installing", "permanent": true },
    { "source": "/guides/bluetooth-printer-setup", "destination": "/troubleshooting/bluetooth-printer-not-pairing", "permanent": true },
    { "source": "/guides/cloud-printing", "destination": "/troubleshooting", "permanent": true },
    { "source": "/guides/airprint-and-mopria", "destination": "/troubleshooting", "permanent": true },
    { "source": "/how-to", "destination": "/troubleshooting", "permanent": true },
    { "source": "/how-to/add-network-printer", "destination": "/troubleshooting/printer-wont-connect-wifi", "permanent": true },
    { "source": "/how-to/clean-print-head", "destination": "/troubleshooting/streaks-or-lines-on-prints", "permanent": true },
    { "source": "/how-to/clear-print-queue", "destination": "/troubleshooting/print-queue-stuck", "permanent": true },
    { "source": "/how-to/find-printer-ip-address", "destination": "/troubleshooting/printer-offline", "permanent": true },
    { "source": "/how-to/install-printer-driver-mac", "destination": "/troubleshooting/driver-not-installing", "permanent": true },
    { "source": "/how-to/install-printer-driver-windows", "destination": "/troubleshooting/driver-not-installing", "permanent": true },
    { "source": "/how-to/print-double-sided", "destination": "/troubleshooting/duplex-not-working", "permanent": true },
    { "source": "/how-to/print-from-android", "destination": "/troubleshooting/printer-offline", "permanent": true },
    { "source": "/how-to/print-from-chromebook", "destination": "/troubleshooting/printer-offline", "permanent": true },
    { "source": "/how-to/print-from-iphone", "destination": "/troubleshooting/printer-offline", "permanent": true },
    { "source": "/how-to/print-poster-multipage", "destination": "/troubleshooting", "permanent": true },
    { "source": "/how-to/replace-toner-cartridge", "destination": "/troubleshooting/ghost-or-faded-prints", "permanent": true },
    { "source": "/how-to/restart-print-spooler", "destination": "/troubleshooting/print-spooler-keeps-stopping", "permanent": true },
    { "source": "/how-to/scan-to-computer", "destination": "/troubleshooting/scanner-not-found", "permanent": true },
    { "source": "/how-to/scan-to-email", "destination": "/troubleshooting/scanner-not-found", "permanent": true },
    { "source": "/how-to/scan-to-pdf", "destination": "/troubleshooting/scanner-not-found", "permanent": true },
    { "source": "/how-to/share-printer-mac", "destination": "/troubleshooting/printer-offline", "permanent": true },
    { "source": "/how-to/share-printer-windows", "destination": "/troubleshooting/printer-offline", "permanent": true },
    { "source": "/how-to/update-printer-firmware", "destination": "/troubleshooting/driver-not-installing", "permanent": true },
    { "source": "/tech", "destination": "/drivers", "permanent": true },
    { "source": "/tech/airprint-explained", "destination": "/troubleshooting", "permanent": true },
    { "source": "/tech/cups-explained", "destination": "/drivers", "permanent": true },
    { "source": "/tech/dpi-explained", "destination": "/drivers", "permanent": true },
    { "source": "/tech/duplex-printing-explained", "destination": "/troubleshooting/duplex-not-working", "permanent": true },
    { "source": "/tech/ipp-everywhere-explained", "destination": "/drivers/network", "permanent": true },
    { "source": "/tech/laser-vs-inkjet", "destination": "/drivers", "permanent": true },
    { "source": "/tech/mopria-explained", "destination": "/troubleshooting", "permanent": true },
    { "source": "/tech/pcl-vs-postscript", "destination": "/drivers", "permanent": true },
    { "source": "/tech/print-spooler-explained", "destination": "/troubleshooting/print-spooler-keeps-stopping", "permanent": true },
    { "source": "/tech/twain-explained", "destination": "/drivers/scanner", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://bat.bing.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://bat.bing.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self';" }
      ]
    },
    {
      "source": "/assets/(.*)\\.(css|js|png|jpg|jpeg|webp|svg|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
      ]
    }
  ]
}
